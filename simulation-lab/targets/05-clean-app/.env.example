# Copy this file to .env.local and fill in real values.
# These are server-only secrets — they are read with process.env on the server
# and are NEVER sent to the browser. Do not prefix any of them with NEXT_PUBLIC_.

# 32+ byte random string used to sign session cookies.
SESSION_SECRET=changeme-use-a-long-random-value

# Postgres connection string for the notes database.
DATABASE_URL=postgres://user:changeme@localhost:5432/notes

# Public, non-secret values (safe to expose to the browser).
NEXT_PUBLIC_APP_NAME=Secure Notes
